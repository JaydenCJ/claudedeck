{
  "env": {
    "ANTHROPIC_API_KEY": "sk-ant-api03-fixture-secret-000000000000",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "32000"
  },
  "apiKeyHelper": "/home/dev/bin/get-key.sh",
  "permissions": {
    "allow": ["Bash(npm test)", "Bash(npm run build)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "echo pre-bash >> /tmp/hooks.log", "timeout": 10 }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "git status --short" }
        ]
      }
    ]
  },
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": { "GITHUB_TOKEN": "ghp_fixture_secret" }
    },
    "slack": {
      "url": "https://mcp.slack.com/mcp",
      "headers": { "Authorization": "Bearer xoxb-fixture" }
    }
  }
}
